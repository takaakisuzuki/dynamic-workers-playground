    "@cloudflare/kumo": "^1.16.0",
    "@cloudflare/worker-bundler": "*",
    "@phosphor-icons/react": "^2.1.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "tailwindcss": "^4.2.2"
  }
}
